{
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/renewal-reminder",
      "schedule": "0 9 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Permissions-Policy",
          "value": "camera=(self), microphone=(self)"
        }
      ]
    }
  ]
}